server {
    listen 80;
    listen [::]:80;
    server_name {{ probe_hostname }};

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location = /ping {
        proxy_pass http://127.0.0.1:8080;
    }

    location = /mtr {
        proxy_set_header X-Real-IP $remote_addr;
        proxy_pass http://127.0.0.1:8080;
        proxy_read_timeout 60s;
    }

    location / {
        return 404;
    }
}
