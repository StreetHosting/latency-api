# Copy to /etc/latency-probe/probe.env on each VPS and adjust per node.
LISTEN_ADDR=127.0.0.1:8080

# Exact origins (comma-separated). Subdomains of the suffixes below are allowed automatically.
ALLOWED_ORIGINS=http://localhost:3000

# Base domains: https://<anything>.streethosting.com.br, .strt.host, .ruas.run (and apex).
ALLOWED_ORIGIN_SUFFIXES=streethosting.com.br,strt.host,ruas.run

# Optional: add more exact origins (e.g. Vercel preview) without opening a whole domain:
# ALLOWED_ORIGINS=http://localhost:3000,https://street-hosting-abc123.vercel.app
