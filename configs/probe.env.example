# Copy to /etc/latency-probe/probe.env on each VPS and adjust per node.
LISTEN_ADDR=127.0.0.1:8080

# Comma-separated CORS allowlist (one origin echoed per response).
ALLOWED_ORIGINS=https://streethosting.com.br,https://www.streethosting.com.br,http://localhost:3000

# Optional: add Vercel preview origins explicitly, e.g.:
# ALLOWED_ORIGINS=...,https://street-hosting-abc123.vercel.app
